<div class="flex flex-row gap-6">
  <div class="flex-shrink my-4 border-l-2 border-base-300 pl-4">
  </div>
  <div class="w-full">
    <div class="form-control mt-1 mb-2 w-full max-w-md">
      <label class="label">
        <span class="label-text">Dockerfile path</span>
      </label>
      <%= render "shared/partials/file_browser",
        form: bc_form,
        field_name: :dockerfile_path,
        label: "Select Dockerfile",
        mode: "file",
        filter_pattern: "Dockerfile",
        default_value: "./Dockerfile",
        current_value: build_configuration.dockerfile_path.presence || "./Dockerfile" %>
      <label class="label">
        <span class="label-text-alt">* Required</span>
      </label>
    </div>
  </div>
</div>
