<%= content_for :title, "Workbench - #{@project.name}" %>

<div class="mb-2 flex items-center gap-2">
  <%= link_to "← Back to original project", project_path(@project.child_dev_environment_fork.parent_project), class: "btn btn-ghost" %>
  <%= link_to "View Project", project_deployments_path(@project), class: "btn btn-ghost" %>
</div>

<h2 class="text-2xl font-bold mb-4">Workbench</h2>

<% if @pod %>
  <%= render "processes/terminal",
    shell_token: @shell_token,
    pod_name: @pod_name,
    namespace: @namespace,
    back_path: project_path(@project.child_dev_environment_fork.parent_project),
    project_name: @project.name,
    cluster: @project.cluster %>
<% else %>
  <% unless @project.deployments.any? %>
    <%= render "shared/partials/wizard_animation" %>
  <% end %>
  <%= render "projects/workbenches/setup_progress", project: @project %>
<% end %>
