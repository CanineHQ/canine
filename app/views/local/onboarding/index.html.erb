<div class="min-h-screen bg-base-100 flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-2xl text-center">
    <img src="/images/logo-full.webp" alt="Canine Logo" class="h-[40px] mx-auto mb-10">

    <h1 class="text-4xl font-bold text-base-content mb-3">
      Set up Canine
    </h1>

    <p class="text-base text-base-content/70 mb-8">
      Create your first account to start using Canine on this cluster.
    </p>

    <% if flash[:alert] %>
      <div class="alert alert-error mb-6 text-left">
        <iconify-icon icon="lucide:alert-triangle" class="mr-2 text-white"></iconify-icon>
        <span><%= flash[:alert] %></span>
      </div>
    <% end %>

    <div class="flex justify-center">
      <%= link_to new_user_registration_url, class: "btn btn-primary btn-lg" do %>
        <iconify-icon icon="lucide:user-plus" width="20" height="20"></iconify-icon>
        Create Your First Account
      <% end %>
    </div>
  </div>
</div>
