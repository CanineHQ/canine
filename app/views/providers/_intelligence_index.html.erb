<% intelligence_providers = current_user.providers.non_sso.where(provider: Provider::INTELLIGENCE_PROVIDERS) %>
<% if intelligence_providers.any? %>
  <div class="overflow-x-auto mb-4">
    <table class="table">
      <thead>
        <tr>
          <th>Provider</th>
          <th>Access Token</th>
          <th>Last Used</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% intelligence_providers.each do |provider| %>
          <tr>
            <td class="flex items-center gap-2">
              <% if provider.openai? %>
                <iconify-icon icon="simple-icons:openai" height="20"></iconify-icon>
              <% elsif provider.anthropic? %>
                <iconify-icon icon="simple-icons:anthropic" height="20"></iconify-icon>
              <% end %>
              <%= provider.provider.titleize %>
            </td>
            <td>
              <% if provider.access_token %>
                <%= provider.abbreviated_access_token %>
              <% else %>
                <span class="text-gray-500">N/A</span>
              <% end %>
            </td>
            <td>
              <%= (provider.last_used_at.strftime("%b %d, %Y") if provider.last_used_at) || "Never" %>
            </td>
            <td>
              <%= link_to "Delete", provider, method: :delete, class: "btn btn-error btn-sm",
                data: { turbo_confirm: "Are you sure?", turbo_frame: "intelligence_provider" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-sm text-base-content/60 mb-4">No AI provider credentials configured yet.</p>
<% end %>
